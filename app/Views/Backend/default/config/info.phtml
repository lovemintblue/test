                                <textarea name="<?php echo $item['code'] ?>"
                                          class="layui-textarea"><?php echo $item['value'] ?></textarea>
                            <?php elseif ($item['type'] == 3):?>
                                <?php $values = explode(';', $item['values']);?>
                                <?php foreach ($values as $value):?>
                                    <?php $value = explode('|', $value);?>
                                    <input type="radio" class="flat" name="<?php echo $item['code'] ?>"
                                           value="<?php echo $value[0] ?>"
                                           title="<?php echo $value[1] ?>" <?php if ($value[0] == $item['value']): ?> checked=""<?php endif; ?> />
                                <?php endforeach;?>
                            <?php elseif ($item['type'] == 4):?>
                                <textarea style="height:300px;visibility:hidden;" name="<?php echo $item['code'] ?>"
                                          class="layui-textarea editer-text"><?php echo $item['value'] ?></textarea>
                            <?php elseif ($item['type'] == 5):?>
                                <?php $values = explode(';', $item['values']);?>
                                <select name="<?php echo $item['code'] ?>">
                                    <option value="">请选择</option>
                                    <?php foreach ($values as $value): ?>
                                        <?php $value = explode('|', $value); ?>
                                        <option <?php if ($value[0] == $item['value']): ?>selected="selected"<?php endif; ?>
                                                value="<?php echo $value[0] ?>"> <?php echo $value[1] ?></option>
                                    <?php endforeach; ?>
                                </select>
                            <?php elseif ($item['type'] == 6)://文件上传?>
                                <button type="button" class="layui-btn btn-upload" >
                                    <i class="layui-icon">&#xe67c;</i>上传图片
                                </button>
                                <input type="hidden" name="<?php echo $item['code']; ?>" class="img-value"  value="<?php echo $item['value']; ?>">
                                <div class="img-show">
                                    <?php if (isset($item['value']) && $item['value']): ?>
                                        <a target="_blank" href="<?php echo $mediaUrl . $item['value']; ?>">
                                            <img src="<?php echo $mediaUrl . $item['value']; ?>" width="100" height="50"/>
                                        </a>
                                    <?php endif; ?>
