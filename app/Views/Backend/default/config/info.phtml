</div>
<script>
    layui.use(['layer', 'form', 'laydate','upload'], function () {
        var $ = layui.jquery;
        var layer = layui.layer;
        var form = layui.form;
        var laydate = layui.laydate;
        var upload = layui.upload;

        /* 监听表单提交 */
        form.on('submit(baseDataFormSubmit)', function (data) {
            doLoadAjax("<?php  echo createUrl('/config/save');?>",data.field,function (res) {
                showSuccessMsg("保存成功!",window.location.href);
            });
            return false;
        });

        //执行实例
        var list = <?php echo json_encode($items);?>;
        $.each(list,function (i,e) {
            if(e.type==6){
                var uploadInst = upload.render({
                    elem: '.btn-upload' //绑定元素
                    ,url: '<?php echo $uploadUrl; ?>' //上传接口
                    ,done: function(res){
                        var item = this.elem;
                        //上传完毕回调
                        item.siblings('.img-value').val(res.data);
                        var showHtml = '<a target="_blank" href="<?php echo $mediaUrl;?>'+res.data+'"><img width="100" height="50" src="<?php echo $mediaUrl;?>'+res.data+'" /></a>';
                        item.siblings('.img-show').html(showHtml);
                    }
                    ,error: function(){
                        //请求异常回调
                    }
                });
            }else if(e.type==7){
                var imgKey = $(".upload-select-picture-cards .card-item").length;
                upload.render({
                    elem: '.'+e.code //绑定元素
                    ,url: '<?php echo $uploadUrl; ?>' //上传接口
                    ,multiple: true
                    ,done: function(res){
                        var html= [
                            '<div style="margin-bottom: 8px" class="card-item">',
                            '<input type="hidden" lay-verify="required" required name="'+e.code+'['+imgKey+']" value="'+res.data+'">',
                            '<a target="_blank" href="<?php echo $mediaUrl;?>'+res.data+'"><img width="102" height="102" src="<?php echo $mediaUrl;?>'+res.data+'"></a>',
                            '<i class="del layui-icon layui-icon-close" lay-active="del"></i>',
                            '</div>',
                        ].join('');
                        $(".upload-select-picture-cards .cares").append(html);
                        imgKey++;
                    }
                    ,error: function(){
                        //请求异常回调
                    }
                });
            }
        });
    });
</script>