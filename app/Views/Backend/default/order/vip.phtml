<script>
    var layerIndex,layer,table,form,laydate,$;
    layui.use(['layer', 'form', 'table', 'admin','laydate'], function () {
        $ = layui.jquery;
        layer = layui.layer;
        form = layui.form;
        table = layui.table;
        laydate = layui.laydate;

        /*初始化表格*/
        table.render({
            elem: '#table'
            ,url: location.href
            ,method: "post"
            ,where: form.val("searchForm")
            ,skin:'line'
            ,size: 'sm' //小尺寸的表格
            ,toolbar: '#table-toolbar'
            ,request: {
                limitName: 'pageSize' //每页数据量的参数名，默认：limit
            }
            ,page: {
                layout: ['prev', 'page', 'next', 'skip', 'count', 'limit']
                ,curr: 1 //设定初始在第 1 页
                ,groups: 6 //只显示 5 个连续页码
                ,first: '首页'
                ,last: '尾页'
                ,limit:30
                ,limits:[10,30,50,100]
            }
            ,totalRow:true
            ,parseData: function(res){ //res 即为原始返回的数据
                return res;
            }
            ,cols: [[
                {field: '_id', title: '编号',width:90, align: 'center',sort:true},
                {field: 'order_sn', title: '订单编号',align: 'center', sort:true},
                {field: 'user_id', title: '用户编号',width:100,align: 'center'},
                {field: 'group_name', title: '用户组',width:100,align: 'center'},
                {field: 'channel_name', title: '渠道',width:120,align: 'center'},
                {field: 'device_type', title: '设备',width:80,align: 'center'},
                {field: 'price', title: '价格',width:80,align: 'center'},
                {field: 'real_price', title: '实际价格',width:90,align: 'center'},
                {field: 'day_num', title: '天数',width:80,align: 'center'},
                {field: 'discount_coupon', title: '折扣券/张',width:80,align: 'center'},
                // {field: 'gift_num', title: '金币',width:60,align: 'center'},
                {field: 'trade_sn', title: '交易单号',width:220,align: 'center', sort:true},
                {field: 'pay_id', title: '支付方式',width:90,align: 'center'},
                {field: 'pay_name',title: '支付方式',width:90,align: 'center'},
                {field: 'status_text', title: '状态',width:80,align: 'center'},
                {field: 'pay_at', title: '支付时间',width:120,align: 'center', sort:true},
                {field: 'created_at', title: '创建时间',width:120,align: 'center', sort:true}
            ]],
        });
        /*表格搜索事件*/
        form.on('submit(searchFormBtn)', function(obj){
            table.reload('table',{where:obj.field,page:{curr:1}});
            return false;
        });
        /*表格排序事件*/
        table.on('sort(table)', function(obj){
            var order=obj.type==='asc'?1:-1;
            table.reload('table', {initSort: obj,where: {sort: obj.field,order: order }});
        });
        laydate.render({
            elem: '#start_time'//指定元素
            , trigger: 'click'
            , type: 'datetime'
        });
        laydate.render({
            elem: '#end_time'//指定元素
            , trigger: 'click'
            , type: 'datetime'
        });
        laydate.render({
            elem: '#cre_start_time'//指定元素
            , trigger: 'click'
            , type: 'datetime'
        });
        laydate.render({
            elem: '#cre_end_time'//指定元素
            , trigger: 'click'
            , type: 'datetime'
        });
        laydate.render({
            elem: '#reg_start_time'//指定元素
            , trigger: 'click'
            , type: 'datetime'
        });
        laydate.render({
            elem: '#reg_end_time'//指定元素
            , trigger: 'click'
            , type: 'datetime'
        });
    })
</script>
